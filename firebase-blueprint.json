{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "noShowCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "noShowCount"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Event tracking details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "creatorId", "startTime", "location", "status"]
    },
    "Participant": {
      "title": "Participant",
      "description": "User participation in an activity",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string", "enum": ["joined", "arrived", "no-show"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "joinedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "activities/{activityId}": {
      "schema": "Activity",
      "description": "Activity details"
    },
    "activities/{activityId}/participants/{userId}": {
      "schema": "Participant",
      "description": "Participant status within an activity"
    }
  }
}
